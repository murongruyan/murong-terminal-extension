# Source code - use LF on all platforms
*.kt text eol=lf
*.kts text eol=lf
*.java text eol=lf
*.xml text eol=lf
*.properties text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.sh text eol=lf
*.py text eol=lf

# Gradle wrapper - must be LF for shebang on Linux
gradlew text eol=lf
gradlew.bat text eol=crlf

# Binary files
*.jar binary
